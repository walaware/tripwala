    "@types/node": "^22",
    "@types/nodemailer": "^8.0.1",
    "svelte": "^5.25.0",
    "svelte-check": "^4.1.5",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.5"
  },
  "dependencies": {
    "@walaware/design": "github:walaware/design#v0.12.0",
