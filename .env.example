# Copy to .env for local Docker overrides (docker-compose reads it automatically).

# Server-side URL the SvelteKit container uses to reach PocketBase.
# Default in compose is the service name; override only if you change topology.
# PB_URL=http://pocketbase:8090

# For local (non-Docker) dev, the web app defaults to http://127.0.0.1:8090.
