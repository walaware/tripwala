# Copy to .env for local Docker runs. docker compose reads it automatically.
#
# In production (homelab), keep real secrets in 1Password and reference them with
# op:// URIs, then start the stack with:
#   op run -- docker compose up -d
# Never commit a real .env (it's gitignored).

# --- PocketBase superuser ---
# The SvelteKit server authenticates as this superuser to read/write while
# collection API rules are locked to superuser-only. PocketBase auto-creates it
# on first boot from these values, and the web service uses the same ones.
PB_SUPERUSER_EMAIL=admin@tripwala.local
# Dev default below; in prod use a strong secret, e.g.:
#   PB_SUPERUSER_PASSWORD=op://<your-vault>/tripwala/superuser-password
PB_SUPERUSER_PASSWORD=change-me-in-production

# --- Server-side PocketBase URL ---
# Defaults to the compose service name; override only if topology changes.
# PB_URL=http://pocketbase:8090

# --- Upload size limit ---
# Max request body adapter-node accepts. Defaults to 8M here so the 5 MB photo
# and avatar uploads work; adapter-node's own default (512K) silently kills them.
# BODY_SIZE_LIMIT=8M

# --- Google OAuth2 (sign-in) ---
# Create a "Web application" OAuth client in Google Cloud Console and register
# these redirect URIs:
#   https://<your-domain>/auth/callback
#   http://localhost:5173/auth/callback   (local dev)
# Then set the client id/secret here (op:// URIs in prod). The auth migration
# reads them to enable the Google provider.
#
# REQUIRED. Google is the ONLY way to sign in — email/password login was removed
# (there is no password-reset flow, so a forgotten password is unrecoverable).
# Leaving these empty means nobody can sign in at all.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#   GOOGLE_OAUTH_CLIENT_SECRET=op://<your-vault>/tripwala/google-oauth-client-secret

# --- Email (invite-by-email) ---
# Optional SMTP relay for sending trip invites. Leave empty to disable the
# "invite by email" field (the app runs fine without it). Any SMTP relay works;
# tripwala uses Resend.
#
# Resend setup (one time):
#   1. resend.com → Domains → Add Domain → enzoiwith.us
#   2. Add the DNS records it prints (an MX + two TXT: SPF and DKIM) to the zone,
#      then click Verify. Without these, mail lands in spam or is rejected.
#   3. API Keys → Create, scope "Sending access". Copy the re_… key.
#   4. SMTP_USER is the LITERAL string "resend" — not your email. The API key is
#      the password.
#   5. SMTP_FROM must be on the verified domain, or Resend rejects the send.
#
# In prod keep the key in 1Password and start with `op run -- docker compose up -d`.
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASS=op://<your-vault>/tripwala/resend-api-key
#   SMTP_FROM=tripwala <trips@enzoiwith.us>
#
# Verify a real send end-to-end before trusting it:
#   pnpm --dir web email:preview you@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Immich (shared photo albums, #21) ---
# OPTIONAL fallback/seed for the Immich connection. The instance admin can set
# these in the UI (Profile → Instance settings), which overrides env. Provide
# them here only if you'd rather pre-configure via env. Leave empty to disable
# the "create shared album" option until set in the UI.
# A private/LAN URL is fine — it's your own server, fetched server-side.
#   IMMICH_URL=http://192.168.1.10:2283
#   IMMICH_API_KEY=op://<your-vault>/tripwala/immich-api-key
IMMICH_URL=
IMMICH_API_KEY=

# --- Instance admin ---
# Who may edit instance settings (/admin). Defaults to the FIRST user who signed
# up. Set this to pin a specific account instead (e.g. if you invited others
# before claiming admin yourself).
#   ADMIN_EMAIL=you@example.com
ADMIN_EMAIL=
