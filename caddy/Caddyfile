# Single entry point.
#
# Local dev over the stack uses :80 inside the container, published as :8080.
# For production, replace `:80` with your domain and Caddy auto-provisions TLS.
#
# PocketBase is NOT a public API. The browser never talks to it directly — every
# read goes through a SvelteKit `load()` and every write through a server
# endpoint, both using the internal superuser client over the docker network.
# The ONE exception is uploaded files (avatars, location photos, OG images),
# which are <img src>'d straight from PocketBase's file endpoint.
#
# So only /api/files/* is exposed. Everything else under /api — crucially
# /api/collections/users/records (create) and .../auth-with-password — stays
# unreachable from the internet, along with the /_/ superuser dashboard.
# Without this, `users.createRule = ""` (which OAuth2 sign-up requires; see the
# users_create_rule migration) would let anyone create an account and sign in
# with a password, defeating Google-only auth.
#
# Reaching the PocketBase dashboard as an operator: don't expose it here. Use
#   docker compose -f compose.yml -f compose.dev.yml up -d pocketbase
# locally, or an SSH tunnel to the host:
#   ssh -L 8090:127.0.0.1:8090 <host>   →   http://127.0.0.1:8090/_/
#
# Caddy sorts `handle` blocks by path specificity, so /api/files/* is matched
# before the /api/* deny-all below it.
#
# Upstreams are env-parameterized so ONE file serves every environment. The
# defaults match this repo's compose service names. The homelab deployment names
# its containers differently and overrides them on the caddy service:
#
#   PB_UPSTREAM=tripwala-pocketbase:8090
#   WEB_UPSTREAM=tripwala-web:3000
#
# Before this, prod kept a hand-edited copy with its own hostnames, and the two
# silently diverged — a redeploy from the other copy would have re-opened the
# PocketBase API and the /_/ dashboard to the internet.

:80 {
	# Uploaded files only — the sole PocketBase surface the browser needs.
	handle /api/files/* {
		reverse_proxy {$PB_UPSTREAM:pocketbase:8090}
	}

	# Personal API keys (walaware API Access, "Personal keys"): the ONLY app-data
	# API on the public edge, and it is SvelteKit-served — the app server reuses its
	# own per-user/per-role authz so a key can't exceed its owner. It goes to
	# WEB_UPSTREAM, NOT PocketBase. More specific than /api/* below, so Caddy matches
	# it first; /api/collections/* and /_/ stay 404 here (only the curated door
	# opens). The tailnet :8091 site keeps its own /api/x/*→PB block for service tokens.
	handle /api/x/* {
		reverse_proxy {$WEB_UPSTREAM:web:3000}
	}

	# Everything else on PocketBase: not public. 404 rather than 403 so the
	# endpoints don't advertise that a PocketBase lives behind here.
	handle /api/* {
		respond 404
	}
	handle /_/* {
		respond 404
	}

	# Everything else → SvelteKit (adapter-node) server.
	handle {
		reverse_proxy {$WEB_UPSTREAM:web:3000}
	}
}

# --- API Access: tailnet-only curated surface (walaware API Access standard) ---
#
# A SEPARATE site from the public :80 edge above (which is unchanged). It exposes
# ONLY the curated /api/x/* routes — never the raw /api/collections/* API, never
# the /_/ admin dashboard. Consumers authenticate with a scoped `api_clients`
# token (see pb_hooks/api_x.pb.js and docs/for-api.md); the token is NOT a
# superuser.
#
# This listens on plain HTTP :8091, published to 127.0.0.1 only (see
# compose.prod.yml). The host fronts it with Tailscale, which terminates TLS and
# restricts reachability to the trusted tailnet — the site is never on the public
# internet:
#
#   tailscale serve --bg --https 443 http://127.0.0.1:8091
#
# Consumers then reach:  https://<host>.<tailnet>.ts.net/api/x/v1/...  (= TRIPWALA_API_URL)
:8091 {
	handle /api/x/* {
		reverse_proxy {$PB_UPSTREAM:pocketbase:8090}
	}
	# Everything else (raw API, /_/ dashboard, files) 404s on this site.
	handle {
		respond 404
	}
}
